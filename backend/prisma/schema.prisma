generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// USUÁRIOS E CLIENTES
// ==========================================

model Usuario {
  id                 String                   @id @default(uuid())
  nome               String
  email              String                   @unique
  senha              String
  perfil             Perfil                   @default(ADMIN)
  permissoes         Json?                    @default("{}")
  deveTrocarSenha    Boolean                  @default(false)
  foto               String? // URL ou data-URL base64 da foto pessoal
  criadoEm           DateTime                 @default(now())
  atualizadoEm       DateTime                 @updatedAt
  clienteId          String?
  alertas            Alerta[]
  cliente            Cliente?                 @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  credenciaisCriadas Credencial[]
  notificacoes       Notificacao[]
  preferenciasNotif  PreferenciaNotificacao[]
  especialista       Especialista?

  @@map("usuarios")
}

model Cliente {
  id                     String                 @id @default(uuid())
  nome                   String
  email                  String?                @unique
  telefone               String?
  segmento               SegmentoCliente?
  plano                  Plano                  @default(BASIC)
  status                 StatusCliente          @default(ACTIVE)
  mensalidade            Float                  @default(0)
  observacoes            String?
  modulosLiberados       Json                   @default("{}")
  brandLogo              String? // URL ou data-URL base64 do logo
  brandNome              String? // Nome customizado que substitui "Sellergy Cloud" no menu
  criadoEm               DateTime               @default(now())
  atualizadoEm           DateTime               @updatedAt
  alertas                Alerta[]
  agendamentos           Agendamento[]
  bots                   Bot[]
  etapasLead             EtapaLead[]
  leads                  Lead[]
  vendas                 Venda[]
  usuarios               Usuario[]
  produtos               Produto[]
  lancamentosFinanceiros LancamentoFinanceiro[]
  categoriasFinanceiras  CategoriaFinanceira[]
  saldosHistorico        SaldoHistorico[]
  credenciais            Credencial[]
  sessoesCaixa           SessaoCaixa[]
  contasPagar            ContaPagar[]
  notificacoes           Notificacao[]
  relatoriosMensais      RelatorioMensal[]
  especialistas          Especialista[]
  cobrancas              Cobranca[]
  configuracaoPagamento  ConfiguracaoPagamento?
  documentosFiscais      DocumentoFiscal[]
  configuracaoFiscal     ConfiguracaoFiscal?
  faqs                   Faq[]
  // Horario de funcionamento (JSON). Usado pelo cron pra abrir/fechar caixa
  // automatico do bot. Formato sugerido:
  //   { "abertura": "08:00", "fechamento": "18:00", "dias": [1,2,3,4,5] }
  // Nullable: sem isso, cron usa default 00:00.
  horarioFuncionamento   Json?

  @@map("clientes")
}

// Movimentacoes manuais de saldo no caixa fisico. NAO confunde com
// LancamentoFinanceiro (que e contabil/receita-despesa). Aqui e operacional:
//   - SUPRIMENTO: dinheiro entrando no caixa (troco, abertura)
//   - SANGRIA:    dinheiro saindo do caixa (deposito banco, retirada socio)
//   - AJUSTE:     correcao manual (conferencia divergente) — legado, em desuso
//
// Quando vinculada a uma sessao de caixa, conta no saldo esperado do
// fechamento. valor sempre positivo; o `tipo` decide a direcao.
model SaldoHistorico {
  id            String             @id @default(uuid())
  clienteId     String
  valor         Float
  tipo          TipoMovimentoCaixa @default(AJUSTE)
  motivo        String?
  sessaoCaixaId String?
  // Auditoria: snapshot do usuario que fez o ajuste. usuarioId pode virar
  // null se o usuario for deletado depois; o nome fica preservado.
  usuarioId     String?
  usuarioNome   String?
  data          DateTime           @default(now())

  cliente Cliente      @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  sessao  SessaoCaixa? @relation(fields: [sessaoCaixaId], references: [id], onDelete: SetNull)

  @@index([sessaoCaixaId, data])
  @@map("saldo_historico")
}

enum TipoMovimentoCaixa {
  SUPRIMENTO
  SANGRIA
  AJUSTE
}

// Sessao de caixa: 1 sessao aberta por vez por tenant.
//   - origem MANUAL: aberta pelo usuario com fundo de caixa inicial
//   - origem AUTO_BOT: criada pelo cron 00:00 (ou ao chegar venda do bot sem caixa)
//
// Saldo esperado = fundoCaixa + soma(vendas RECEITA da sessao) + suprimentos - sangrias
// Diferenca = saldoFinalReal - saldoFinalEsperado (positivo = sobra; negativo = falta)
model SessaoCaixa {
  id                   String            @id @default(uuid())
  clienteId            String
  fundoCaixa           Float             @default(0)
  saldoFinalEsperado   Float?
  saldoFinalReal       Float?
  diferenca            Float?
  observacaoAbertura   String?
  observacaoFechamento String?
  // Auditoria de quem abriu/fechou. Snapshot do nome pra preservar.
  usuarioAbriuId       String?
  usuarioAbriuNome     String?
  usuarioFechouId      String?
  usuarioFechouNome    String?
  abertaEm             DateTime          @default(now())
  fechadaEm            DateTime?
  status               StatusSessaoCaixa @default(ABERTA)
  origem               OrigemSessaoCaixa @default(MANUAL)

  cliente            Cliente                @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  vendas             Venda[]
  lancamentos        LancamentoFinanceiro[]
  movimentacoesSaldo SaldoHistorico[]

  @@index([clienteId, status])
  @@index([clienteId, abertaEm])
  @@map("sessoes_caixa")
}

enum StatusSessaoCaixa {
  ABERTA
  FECHADA
}

enum OrigemSessaoCaixa {
  MANUAL
  AUTO_BOT
}

// ==========================================
// BOTS E AUTOMAÇÃO
// ==========================================

model Bot {
  id                 String        @id @default(uuid())
  clienteId          String
  nome               String
  canal              Canal         @default(WHATSAPP)
  status             StatusBot     @default(OFFLINE)
  telefone           String?
  totalMensagens     Int           @default(0)
  mensagensHoje      Int           @default(0)
  ultimaAtividadeEm  DateTime?
  criadoEm           DateTime      @default(now())
  atualizadoEm       DateTime      @updatedAt
  // Canal externo (WhatsApp Cloud, Telegram, etc.):
  //   credencialCanalId  -> Credencial (token do canal)
  //   identificadorCanal -> ex: phoneNumberId do WhatsApp / chatId do Telegram
  //   verifyTokenCanal   -> verify token usado pela Meta no GET de verificacao
  credencialCanalId  String?
  identificadorCanal String?
  verifyTokenCanal   String?
  // Configuracao do menu fixo do bot (sem IA) — roteador de atendimento/
  // agendamento por opcoes. Formato livre (JSON), preenchido pela Frente 4.
  menuConfig         Json?
  alertas            Alerta[]
  variaveis          VariavelBot[]
  cliente            Cliente       @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("bots")
}

model VariavelBot {
  id           String       @id @default(uuid())
  botId        String
  chave        String
  valor        String
  descricao    String?
  tipo         TipoVariavel @default(TEXT)
  criadoEm     DateTime     @default(now())
  atualizadoEm DateTime     @updatedAt
  bot          Bot          @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([botId, chave])
  @@map("bot_variaveis")
}

// ==========================================
// EXECUCAO DE FLUXOS (Engine)
// ==========================================

// ==========================================
// CRM E LEADS
// ==========================================

model EtapaLead {
  id           String   @id @default(uuid())
  clienteId    String
  nome         String
  ordem        Int
  cor          String?
  // slug do catalogo de etapas pre-definidas (ex: 'novo', 'qualificado').
  // Nullable pra acomodar etapas legadas com nome livre (pre-catalogo).
  // Combinacao (clienteId, slug) e unica — o tenant nao pode habilitar a
  // mesma etapa do catalogo 2x. Slug NULL e permitido multiplos (legados).
  slug         String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  cliente      Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  leads        Lead[]

  @@unique([clienteId, slug])
  @@map("lead_etapas")
}

model Lead {
  id                     String                 @id @default(uuid())
  clienteId              String
  etapaId                String?
  nome                   String
  telefone               String?
  email                  String?
  // CPF do cliente — armazenado so com digitos (sem mascara). Nullable
  // porque lead inicial pode chegar sem. Nao e unique: cliente recorrente
  // pode virar lead de novo no funil.
  cpf                    String?
  // Data de nascimento — usado pra parabens automatico, segmentacao etaria.
  dataNascimento         DateTime?
  valor                  Float?
  observacoes            String?
  ultimoContato          DateTime?
  criadoEm               DateTime               @default(now())
  atualizadoEm           DateTime               @updatedAt
  tags                   String?
  prioridade             Prioridade             @default(MEDIUM)
  origem                 String?
  agendamentos           Agendamento[]
  historico              HistoricoLead[]
  cliente                Cliente                @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  etapa                  EtapaLead?             @relation(fields: [etapaId], references: [id])
  mensagens              Mensagem[]
  vendas                 Venda[]
  lancamentosFinanceiros LancamentoFinanceiro[]
  variacoes              LeadVariacao[]

  @@map("leads")
}

model HistoricoLead {
  id          String   @id @default(uuid())
  leadId      String
  acao        String
  deEtapa     String?
  paraEtapa   String?
  observacoes String?
  criadoEm    DateTime @default(now())
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_historico")
}

model Mensagem {
  id       String   @id @default(uuid())
  leadId   String
  conteudo String
  doBot    Boolean  @default(false)
  criadoEm DateTime @default(now())
  lead     Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("mensagens")
}

model Agendamento {
  id              String            @id @default(uuid())
  clienteId       String
  leadId          String?
  nomeCliente     String
  telefoneCliente String?
  duracao         Int               @default(30)
  origem          OrigemAgendamento @default(MANUAL)
  data            DateTime
  servico         String?
  preco           Float?
  status          StatusAgendamento @default(PENDING)
  observacoes     String?
  // Especialista (recurso agendavel) que vai atender. Nullable: agendamentos
  // legados ou de tenant sem especialistas cadastrados. SetNull pra preservar
  // o agendamento se o especialista for removido.
  especialistaId  String?
  criadoEm        DateTime          @default(now())
  atualizadoEm    DateTime          @updatedAt

  cliente      Cliente                @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  lead         Lead?                  @relation(fields: [leadId], references: [id])
  especialista Especialista?          @relation(fields: [especialistaId], references: [id], onDelete: SetNull)
  venda        Venda?
  historico    HistoricoAgendamento[]

  @@index([especialistaId, data])
  @@map("agendamentos")
}

// Log auditavel de toda mudanca em agendamento.
// acao: CRIADO | EDITADO | STATUS_MUDADO | EXCLUIDO
// alteracoes: JSON com { campo: { de, para } } pra cada campo modificado
// usuarioId/usuarioNome: quem fez. Null pra acoes do bot (origem AI).
//
// agendamentoId e nullable + ON DELETE SET NULL pra log de EXCLUIDO sobreviver
// a delete do proprio agendamento (auditoria precisa preservar o trail mesmo
// depois). Quando isso acontece, identificamos pelo snapshot guardado nas
// alteracoes.
model HistoricoAgendamento {
  id            String   @id @default(uuid())
  agendamentoId String?
  acao          String
  alteracoes    Json?
  usuarioId     String?
  usuarioNome   String?
  origem        String?
  criadoEm      DateTime @default(now())

  agendamento Agendamento? @relation(fields: [agendamentoId], references: [id], onDelete: SetNull)

  @@index([agendamentoId, criadoEm])
  @@map("agendamento_historico")
}

// ==========================================
// ESPECIALISTAS (recurso agendavel — perfil Servico)
// ==========================================
// Especialista = quem executa servicos e pode ser agendado (barbeiro,
// dentista, esteticista). Pode ou nao ter login (usuarioId opcional 1:1).
// A capacidade de um horario = nº de especialistas aptos ao servico e livres.
model Especialista {
  id           String   @id @default(uuid())
  clienteId    String
  // Vinculo opcional 1:1 com um Usuario (login). Especialista sem usuario =
  // so agendavel (ex.: barbeiro que nao acessa o sistema). @unique garante
  // que um usuario seja, no maximo, um especialista.
  usuarioId    String?  @unique
  nome         String
  ativo        Boolean  @default(true)
  // Jornada de trabalho (JSON). null = herda o expediente da loja
  // (Cliente.horarioFuncionamento). Formato por dia (1=segunda..7=domingo):
  //   { "1": [{ "inicio": "08:00", "fim": "12:00" }, { "inicio": "13:00", "fim": "18:00" }], ... }
  jornada      Json?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  cliente      Cliente               @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  usuario      Usuario?              @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  servicos     EspecialistaServico[]
  agendamentos Agendamento[]

  @@index([clienteId, ativo])
  @@map("especialistas")
}

// M:N entre Especialista e Produto (tipo SERVICO): quais servicos cada
// especialista executa. Escolha por nivel Produto ("faz Corte"), nao por
// variacao — cobre as variacoes do servico. A disponibilidade cruza isto com
// a jornada e os agendamentos existentes.
model EspecialistaServico {
  id             String   @id @default(uuid())
  especialistaId String
  produtoId      String
  criadoEm       DateTime @default(now())

  especialista Especialista @relation(fields: [especialistaId], references: [id], onDelete: Cascade)
  produto      Produto      @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@unique([especialistaId, produtoId])
  @@index([produtoId])
  @@map("especialista_servicos")
}

model Venda {
  id                     String                 @id @default(uuid())
  clienteId              String
  // Numero sequencial humano-legivel por tenant. Cada tenant comeca em 1.
  // O `id` UUID continua sendo a chave tecnica (relacionamentos seguros).
  // O `numero` e o que aparece pra cliente final ("Venda #42").
  numero                 Int
  leadId                 String?
  // Sessao de caixa em que a venda foi registrada. Pra venda manual, exige
  // caixa aberto. Pra venda do bot, criada AUTO se nao tem nenhum.
  sessaoCaixaId          String?
  valor                  Float
  metodoPagamento        String?
  status                 StatusVenda            @default(COMPLETED)
  descricao              String?
  data                   DateTime               @default(now())
  dataCancelamento       DateTime?
  motivoCancelamento     String?
  canceladaPorId         String?
  // Quando a venda nasce da conclusao de um agendamento (servico atendido).
  // @unique = 1 venda por agendamento (trava dupla-conclusao no banco). SetNull
  // preserva a venda se o agendamento for apagado.
  agendamentoId          String?                @unique
  criadoEm               DateTime               @default(now())
  atualizadoEm           DateTime               @updatedAt
  cliente                Cliente                @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  lead                   Lead?                  @relation(fields: [leadId], references: [id])
  sessao                 SessaoCaixa?           @relation(fields: [sessaoCaixaId], references: [id], onDelete: SetNull)
  agendamento            Agendamento?           @relation(fields: [agendamentoId], references: [id], onDelete: SetNull)
  lancamentosFinanceiros LancamentoFinanceiro[]
  movimentacoesEstoque   MovimentacaoEstoque[]

  @@unique([clienteId, numero])
  @@index([sessaoCaixaId])
  @@map("vendas")
}

// ==========================================
// MÓDULO DE CATÁLOGO
// ==========================================

model Produto {
  id           String              @id @default(uuid())
  clienteId    String
  categoriaId  String?
  nome         String
  descricao    String?
  tipo         TipoProduto         @default(FISICO)
  visibilidade VisibilidadeProduto @default(ATIVO)
  imagemUrl    String? // URL no MinIO (bucket sellergy-midia)
  criadoEm     DateTime            @default(now())
  atualizadoEm DateTime            @updatedAt

  cliente       Cliente               @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  categoria     CategoriaFinanceira?  @relation(fields: [categoriaId], references: [id])
  variacoes     VariacaoProduto[]
  especialistas EspecialistaServico[]

  @@map("produtos")
}

model VariacaoProduto {
  id            String   @id @default(uuid())
  produtoId     String
  nome          String // Ex: "Tamanho P", "Cor Azul"
  sku           String?  @unique
  preco         Float // Preço de Venda (usado em vendas, agenda e bot)
  precoCusto    Float?   @default(0) // Preço de Compra
  estoqueAtual  Int      @default(0)
  estoqueMinimo Int?     @default(0)
  estoqueIdeal  Int?     @default(0)
  localizacao   String?
  // Duracao em minutos — so faz sentido pra produtos do tipo SERVICO (ex.:
  // "Corte de cabelo: 30min"). Usado pela Agenda pra pre-preencher e
  // calcular conflito de horario. Null pra produtos fisicos.
  duracaoMin    Int?
  imagemUrl     String? // imagem opcional da variacao (ex.: cor azul vs cor vermelha)
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  produto       Produto               @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  movimentacoes MovimentacaoEstoque[]
  vinculosLead  LeadVariacao[]

  @@map("variacoes_produto")
}

// ==========================================
// PRODUTOS VINCULADOS AO LEAD (interesse de compra)
// ==========================================
// Tabela M:N entre Lead e VariacaoProduto, com quantidade pra suportar
// "2x camiseta P + 1x camiseta G". O `valor` agregado do lead e calculado
// no servidor a partir dessa relacao (preco × quantidade).
model LeadVariacao {
  id         String   @id @default(uuid())
  leadId     String
  variacaoId String
  quantidade Int      @default(1)
  observacao String?
  criadoEm   DateTime @default(now())

  lead     Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  variacao VariacaoProduto @relation(fields: [variacaoId], references: [id], onDelete: Cascade)

  @@unique([leadId, variacaoId])
  @@index([leadId])
  @@map("lead_variacoes")
}

// ==========================================
// MÓDULO DE ESTOQUE
// ==========================================

model MovimentacaoEstoque {
  id         String           @id @default(uuid())
  variacaoId String
  tipo       TipoMovimentacao
  quantidade Int // Positivo para entrada, negativo para saída
  motivo     String?
  vendaId    String?
  data       DateTime         @default(now())

  variacao VariacaoProduto @relation(fields: [variacaoId], references: [id], onDelete: Cascade)
  venda    Venda?          @relation(fields: [vendaId], references: [id])

  @@map("movimentacoes_estoque")
}

// ==========================================
// MÓDULO FINANCEIRO
// ==========================================

model LancamentoFinanceiro {
  id                 String           @id @default(uuid())
  clienteId          String
  leadId             String?
  vendaId            String?
  categoriaId        String?
  descricao          String
  produto            String?
  metodoPagamento    String?
  valor              Float
  tipo               TipoLancamento
  status             StatusFinanceiro @default(PENDENTE)
  dataVencimento     DateTime
  dataPagamento      DateTime?
  dataCancelamento   DateTime?
  motivoCancelamento String?
  idAgrupamento      String?
  // Sessao de caixa em que o lancamento foi gerado (so se PAGO e veio de
  // venda/sangria/suprimento da sessao). Receitas/despesas com vencimento
  // futuro nao tem sessao — sao agendamentos contabeis, nao caixa fisico.
  sessaoCaixaId      String?
  // Quando o pagamento veio de uma Conta a Pagar cadastrada (rastreamento
  // de pagamento recorrente). Nullable porque despesas avulsas nao tem.
  contaPagarId       String?
  criadoEm           DateTime         @default(now())
  atualizadoEm       DateTime         @updatedAt

  cliente    Cliente               @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  lead       Lead?                 @relation(fields: [leadId], references: [id])
  venda      Venda?                @relation(fields: [vendaId], references: [id])
  categoria  CategoriaFinanceira?  @relation(fields: [categoriaId], references: [id])
  sessao     SessaoCaixa?          @relation(fields: [sessaoCaixaId], references: [id], onDelete: SetNull)
  contaPagar ContaPagar?           @relation(fields: [contaPagarId], references: [id], onDelete: SetNull)
  historico  HistoricoLancamento[]

  @@index([sessaoCaixaId])
  @@index([contaPagarId])
  @@map("lancamentos_financeiros")
}

// Log auditavel de toda mudanca em lancamento financeiro.
// acao: CRIADO | EDITADO | STATUS_MUDADO | CANCELADO | EXCLUIDO | ADIADO
// alteracoes: JSON com { campo: { de, para } } (ou snapshot pra CRIADO/EXCLUIDO)
// usuarioId/Nome: snapshot pra preservar mesmo apos delete do usuario.
//
// lancamentoId e nullable + ON DELETE SET NULL: log de EXCLUIDO sobrevive
// ao delete do lancamento (auditoria preserva trilha). Snapshot em alteracoes
// identifica o lancamento.
model HistoricoLancamento {
  id           String   @id @default(uuid())
  lancamentoId String?
  acao         String
  alteracoes   Json?
  usuarioId    String?
  usuarioNome  String?
  criadoEm     DateTime @default(now())

  lancamento LancamentoFinanceiro? @relation(fields: [lancamentoId], references: [id], onDelete: SetNull)

  @@index([lancamentoId, criadoEm])
  @@map("lancamento_historico")
}

model CategoriaFinanceira {
  id        String            @id @default(uuid())
  clienteId String
  nome      String
  tipo      TipoLancamento
  // Uso/contexto da categoria — controla em quais telas ela aparece (ver enum
  // UsoCategoria). Nullable: categorias antigas ficam sem uso ate o usuario
  // classificar; novas exigem o uso no cadastro.
  uso       UsoCategoria?
  // SubTipo só se aplica a DESPESA: VARIAVEL (taxas, impostos, comissões —
  // sobem/descem com volume) vs FIXA (aluguel, salário, internet — paga
  // todo mês). Nullable porque RECEITA não usa e categorias antigas ainda
  // não foram migradas. DRE/relatórios fazem fallback ao nome quando null.
  subTipo   SubTipoCategoria?

  cliente     Cliente                @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  lancamentos LancamentoFinanceiro[]
  produtos    Produto[]
  contasPagar ContaPagar[]

  @@map("categorias_financeiras")
}

enum SubTipoCategoria {
  VARIAVEL
  FIXA
}

// "Uso" da categoria (a chave de contexto): define EM QUAIS telas ela aparece.
//   SERVICO  -> cadastro de servico (Catalogo)
//   PRODUTO  -> cadastro de produto / estoque / vendas
//   CAIXA    -> lancamentos avulsos do caixa (sangria, suprimento, avulsos)
//   DESPESA  -> contas a pagar / despesas
// Relatorios e a visao de caixa mostram TODAS (leitura). Nullable = ainda nao
// classificada (aparece so em Configuracoes/Relatorios ate receber um uso).
enum UsoCategoria {
  SERVICO
  PRODUTO
  CAIXA
  DESPESA
}

// =====================================================================
// CONTAS A PAGAR — catalogo de despesas recorrentes/pontuais
// =====================================================================
// Conceito: cadastro de despesas que o usuario precisa pagar (aluguel,
// internet, fornecedor, etc.). NAO e um lancamento — quando o pagamento
// acontece (manualmente ou pelo caixa via "Pagar despesa"), cria um
// LancamentoFinanceiro DESPESA PAGO vinculado.
//
// Periodicidade:
//   - PONTUAL: paga uma unica vez, depois pode ser arquivada
//   - MENSAL: gera lembrete todo mes no diaVencimento
//   - ANUAL: gera lembrete uma vez por ano no diaVencimento+mesVencimento
//
// `ativa` permite pausar sem deletar (preserva historico de pagamentos
// via LancamentoFinanceiro.contaPagarId).

enum PeriodicidadeContaPagar {
  PONTUAL
  MENSAL
  ANUAL
}

model ContaPagar {
  id            String                  @id @default(uuid())
  clienteId     String
  nome          String // ex: "Aluguel", "Internet Vivo"
  valorPadrao   Float // valor sugerido (usuario pode editar no momento do pagamento)
  categoriaId   String? // CategoriaFinanceira tipo DESPESA
  periodicidade PeriodicidadeContaPagar @default(MENSAL)
  diaVencimento Int? // 1-31, opcional pra PONTUAL
  mesVencimento Int? // 1-12, so faz sentido pra ANUAL
  observacoes   String?
  ativa         Boolean                 @default(true)
  criadoEm      DateTime                @default(now())
  atualizadoEm  DateTime                @updatedAt

  cliente    Cliente                @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  categoria  CategoriaFinanceira?   @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  pagamentos LancamentoFinanceiro[]

  @@index([clienteId, ativa])
  @@map("contas_pagar")
}

model Alerta {
  id           String       @id @default(uuid())
  botId        String
  clienteId    String
  usuarioId    String?
  severidade   Severidade   @default(ERROR)
  titulo       String
  mensagem     String
  status       StatusAlerta @default(OPEN)
  resolvidoEm  DateTime?
  criadoEm     DateTime     @default(now())
  atualizadoEm DateTime     @updatedAt
  bot          Bot          @relation(fields: [botId], references: [id], onDelete: Cascade)
  cliente      Cliente      @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  usuario      Usuario?     @relation(fields: [usuarioId], references: [id])

  @@map("alertas")
}

// ==========================================
// CONVERSAS E MENSAGENS (cifradas em repouso)
// ==========================================

model AuditoriaMensagem {
  id         String   @id @default(uuid())
  mensagemId String
  usuarioId  String?
  acao       String // 'LEITURA', 'CRIACAO', 'EXCLUSAO'
  ip         String?
  userAgent  String?
  criadoEm   DateTime @default(now())

  @@index([mensagemId, criadoEm(sort: Desc)])
  @@index([usuarioId])
  @@map("auditoria_mensagens")
}

// Audit append-only de toda chamada de tool feita por agentes IA.
// Permite auditar "o que o bot fez" em cada execucao.
model AuditoriaAcaoAgente {
  id         String   @id @default(uuid())
  execucaoId String
  noId       String?
  toolNome   String
  args       Json?
  sucesso    Boolean
  resultado  Json?
  erro       String?
  duracaoMs  Int?
  criadoEm   DateTime @default(now())

  @@index([execucaoId, criadoEm])
  @@index([toolNome])
  @@map("auditoria_acoes_agente")
}

// Credenciais cifradas (chaves de API de provedores externos: OpenAI,
// Anthropic, WhatsApp Cloud, Telegram, etc.). dadosCifrados guarda um
// objeto JSON serializado e cifrado (AES-256-GCM) — formato livre por tipo.
model Credencial {
  id            String         @id @default(uuid())
  // Nullable: clienteId null = credencial de PLATAFORMA (gerida pelo ADMIN do
  // sistema, ex.: a chave de IA usada por padrao pelos bots). Cifrada com uma
  // chave estavel de plataforma (ver credenciais.js). Tenant tem clienteId.
  clienteId     String?
  nome          String
  tipo          TipoCredencial
  descricao     String?
  dadosCifrados Bytes
  iv            Bytes
  tag           Bytes
  versaoChave   Int            @default(1)
  ultimoUsoEm   DateTime?
  criadoPorId   String?
  criadoEm      DateTime       @default(now())
  atualizadoEm  DateTime       @updatedAt

  cliente   Cliente? @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  criadoPor Usuario? @relation(fields: [criadoPorId], references: [id], onDelete: SetNull)

  @@index([clienteId, tipo])
  @@map("credenciais")
}

// ==========================================
// PAGAMENTOS (PSP) — camada agnostica de provedor
// ==========================================
// Nucleo unico: ConfiguracaoPagamento (escolha do provedor por tenant) +
// Cobranca (agnostica). A logica especifica de cada PSP (Mercado Pago/Asaas/
// Pagar.me) vive nos adaptadores (Frente 2). `provedorCobrancaId` guarda o id
// da cobranca no PSP e e a chave de idempotencia do webhook. `credencialId`
// aponta pra Credencial cifrada no cofre.

model ConfiguracaoPagamento {
  id           String            @id @default(uuid())
  clienteId    String            @unique
  provedor     ProvedorPagamento
  credencialId String?
  ativo        Boolean           @default(true)
  criadoEm     DateTime          @default(now())
  atualizadoEm DateTime          @updatedAt

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("configuracoes_pagamento")
}

model Cobranca {
  id                 String            @id @default(uuid())
  clienteId          String
  origem             OrigemCobranca
  refId              String? // id da Venda/Agendamento de origem (solto — varia por origem)
  valor              Float
  metodo             MetodoCobranca
  status             StatusCobranca    @default(PENDENTE)
  provedor           ProvedorPagamento
  provedorCobrancaId String? // id no PSP — chave de idempotencia do webhook
  qrCode             String? // copia-e-cola / payload do QR Pix
  linkUrl            String?
  vencimento         DateTime?
  pagoEm             DateTime?
  criadoEm           DateTime          @default(now())
  atualizadoEm       DateTime          @updatedAt

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@unique([provedor, provedorCobrancaId])
  @@index([clienteId, status])
  @@index([clienteId, origem, refId])
  @@map("cobrancas")
}

// ==========================================
// FISCAL — emissao terceirizada (API), camada agnostica de provedor
// ==========================================
// Nucleo: ConfiguracaoFiscal (provedor + dados do emissor) + DocumentoFiscal
// (agnostico). Adaptadores Focus NFe / Nuvem Fiscal na Frente 3. Emissao e
// assincrona (fila) — nunca bloqueia a venda.

model ConfiguracaoFiscal {
  id             String         @id @default(uuid())
  clienteId      String         @unique
  provedor       ProvedorFiscal
  credencialId   String?
  regime         String? // regime tributario (Simples/Presumido/Real)
  cnpj           String?
  inscricao      String? // inscricao estadual/municipal
  certificadoRef String? // referencia segura ao certificado digital (nunca o conteudo)
  csc            String? // Codigo de Seguranca do Contribuinte (NFC-e)
  serie          String?
  ambiente       AmbienteFiscal @default(HOMOLOGACAO)
  ativo          Boolean        @default(true)
  criadoEm       DateTime       @default(now())
  atualizadoEm   DateTime       @updatedAt

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("configuracoes_fiscal")
}

model DocumentoFiscal {
  id            String                @id @default(uuid())
  clienteId     String
  vendaId       String? // venda de origem (solto; pode nao existir p/ NFS-e avulsa)
  tipo          TipoDocumentoFiscal
  status        StatusDocumentoFiscal @default(PENDENTE)
  provedor      ProvedorFiscal
  provedorDocId String? // id do documento no provedor
  numero        String?
  chave         String? // chave de acesso (44 digitos)
  urlPdf        String?
  urlXml        String?
  mensagemErro  String?
  criadoEm      DateTime              @default(now())
  atualizadoEm  DateTime              @updatedAt

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId, status])
  @@index([clienteId, vendaId])
  @@map("documentos_fiscais")
}

// ==========================================
// FAQ simples — atendimento basico do bot (sem IA)
// ==========================================
// Pares pergunta/resposta por tenant. Modelo enxuto agora; evolui depois.
// Usado pela Frente 4 no roteador de menu fixo do WhatsApp.

model Faq {
  id           String   @id @default(uuid())
  clienteId    String
  pergunta     String
  resposta     String
  ordem        Int      @default(0)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId, ativo, ordem])
  @@map("faqs")
}

