generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// USUÁRIOS E CLIENTES
// ==========================================

model Usuario {
  id           String   @id @default(uuid())
  nome         String
  email        String   @unique
  senha        String
  perfil       Perfil   @default(ADMIN)
  permissoes   Json?    @default("{}")
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  clienteId    String?
  alertas      Alerta[]
  cliente      Cliente? @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("usuarios")
}

model Cliente {
  id                    String                @id @default(uuid())
  nome                  String
  email                 String?               @unique
  telefone              String?
  segmento              String?
  plano                 Plano                 @default(BASIC)
  status                StatusCliente         @default(ACTIVE)
  mensalidade           Float                 @default(0)
  observacoes           String?
  criadoEm              DateTime              @default(now())
  atualizadoEm          DateTime              @updatedAt
  alertas               Alerta[]
  agendamentos          Agendamento[]
  bots                  Bot[]
  etapasLead            EtapaLead[]
  leads                 Lead[]
  vendas                Venda[]
  usuarios              Usuario[]
  produtos              Produto[]
  lancamentosFinanceiros LancamentoFinanceiro[]
  categoriasFinanceiras CategoriaFinanceira[]
  saldosHistorico       SaldoHistorico[]

  @@map("clientes")
}

model SaldoHistorico {
  id        String   @id @default(uuid())
  clienteId String
  valor     Float
  motivo    String?
  data      DateTime @default(now())

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("saldo_historico")
}

// ==========================================
// BOTS E AUTOMAÇÃO
// ==========================================

model Bot {
  id                String         @id @default(uuid())
  clienteId         String
  nome              String
  canal             Canal          @default(WHATSAPP)
  status            StatusBot      @default(OFFLINE)
  telefone          String?
  totalMensagens    Int            @default(0)
  mensagensHoje     Int            @default(0)
  ultimaAtividadeEm DateTime?
  criadoEm          DateTime       @default(now())
  atualizadoEm      DateTime       @updatedAt
  modeloIa          String?
  provedorIa        ProvedorIA?
  promptSistemaIa   String?
  temperaturaIa     Float?         @default(0.7)
  apiKeyIa          String?
  alertas           Alerta[]
  variaveis         VariavelBot[]
  cliente           Cliente        @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  fluxos            Fluxo[]

  @@map("bots")
}

model VariavelBot {
  id           String   @id @default(uuid())
  botId        String
  chave        String
  valor        String
  descricao    String?
  tipo         TipoVariavel @default(TEXT)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  bot          Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([botId, chave])
  @@map("bot_variaveis")
}

model Fluxo {
  id                  String      @id @default(uuid())
  botId               String
  nome                String
  ativo               Boolean     @default(false)
  tipoGatilho         TipoGatilho @default(KEYWORD)
  palavraChaveGatilho String?
  criadoEm            DateTime    @default(now())
  atualizadoEm        DateTime    @updatedAt
  conexoes            Conexao[]
  bot                 Bot         @relation(fields: [botId], references: [id], onDelete: Cascade)
  nos                 No[]

  @@map("fluxos")
}

model No {
  id           String   @id
  fluxoId      String
  tipo         TipoNo
  posicaoX     Float
  posicaoY     Float
  dados        Json
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  fluxo        Fluxo    @relation(fields: [fluxoId], references: [id], onDelete: Cascade)

  @@map("nos")
}

model Conexao {
  id              String   @id
  fluxoId         String
  noOrigemId      String
  noDestinoId     String
  pontoOrigem     String?
  criadoEm        DateTime @default(now())
  fluxo           Fluxo    @relation(fields: [fluxoId], references: [id], onDelete: Cascade)

  @@map("conexoes")
}

// ==========================================
// CRM E LEADS
// ==========================================

model EtapaLead {
  id           String   @id @default(uuid())
  clienteId    String
  nome         String
  ordem        Int
  cor          String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  cliente      Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  leads        Lead[]

  @@map("lead_etapas")
}

model Lead {
  id                    String                 @id @default(uuid())
  clienteId             String
  etapaId               String?
  nome                  String
  telefone              String?
  email                 String?
  valor                 Float?
  observacoes           String?
  ultimoContato         DateTime?
  criadoEm              DateTime               @default(now())
  atualizadoEm          DateTime               @updatedAt
  tags                  String?
  prioridade            Prioridade             @default(MEDIUM)
  origem                String?
  agendamentos          Agendamento[]
  historico             HistoricoLead[]
  cliente               Cliente                @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  etapa                 EtapaLead?             @relation(fields: [etapaId], references: [id])
  mensagens             Mensagem[]
  vendas                Venda[]
  lancamentosFinanceiros LancamentoFinanceiro[]

  @@map("leads")
}

model HistoricoLead {
  id           String   @id @default(uuid())
  leadId       String
  acao         String
  deEtapa      String?
  paraEtapa    String?
  observacoes  String?
  criadoEm     DateTime @default(now())
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_historico")
}

model Mensagem {
  id        String   @id @default(uuid())
  leadId    String
  conteudo  String
  doBot     Boolean  @default(false)
  criadoEm  DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("mensagens")
}

model Agendamento {
  id              String            @id @default(uuid())
  clienteId       String
  leadId          String?
  nomeCliente     String
  telefoneCliente String?
  duracao         Int               @default(30)
  origem          OrigemAgendamento @default(MANUAL)
  data            DateTime
  servico         String?
  preco           Float?
  status          StatusAgendamento @default(PENDING)
  observacoes     String?
  criadoEm        DateTime          @default(now())
  atualizadoEm    DateTime          @updatedAt

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  lead    Lead?   @relation(fields: [leadId], references: [id])

  @@map("agendamentos")
}

model Venda {
  id                    String                @id @default(uuid())
  clienteId             String
  leadId                String?
  valor                 Float
  metodoPagamento       String?
  status                StatusVenda           @default(COMPLETED)
  descricao             String?
  data                  DateTime              @default(now())
  criadoEm              DateTime              @default(now())
  atualizadoEm          DateTime              @updatedAt
  cliente               Cliente               @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  lead                  Lead?                 @relation(fields: [leadId], references: [id])
  lancamentosFinanceiros LancamentoFinanceiro[]
  movimentacoesEstoque  MovimentacaoEstoque[]

  @@map("vendas")
}

// ==========================================
// MÓDULO DE CATÁLOGO
// ==========================================

model Produto {
  id            String              @id @default(uuid())
  clienteId     String
  categoriaId   String?
  nome          String
  descricao     String?
  tipo          TipoProduto         @default(FISICO)
  visibilidade  VisibilidadeProduto @default(ATIVO)
  criadoEm      DateTime            @default(now())
  atualizadoEm  DateTime            @updatedAt

  cliente   Cliente              @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  categoria CategoriaFinanceira? @relation(fields: [categoriaId], references: [id])
  variacoes VariacaoProduto[]

  @@map("produtos")
}

model VariacaoProduto {
  id            String   @id @default(uuid())
  produtoId     String
  nome          String // Ex: "Tamanho P", "Cor Azul"
  sku           String?  @unique
  preco         Float // Preço de Venda
  precoCusto    Float?   @default(0) // Preço de Compra
  estoqueAtual  Int      @default(0)
  estoqueMinimo Int?     @default(0) // Alerta de falta
  estoqueIdeal  Int?     @default(0) // Alvo de reposição
  localizacao   String? // Ex: "Corredor A, Prateleira 2"
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  produto       Produto               @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  movimentacoes MovimentacaoEstoque[]

  @@map("variacoes_produto")
}

// ==========================================
// MÓDULO DE ESTOQUE
// ==========================================

model MovimentacaoEstoque {
  id         String           @id @default(uuid())
  variacaoId String
  tipo       TipoMovimentacao
  quantidade Int // Positivo para entrada, negativo para saída
  motivo     String?
  vendaId    String?
  data       DateTime         @default(now())

  variacao VariacaoProduto @relation(fields: [variacaoId], references: [id], onDelete: Cascade)
  venda    Venda?           @relation(fields: [vendaId], references: [id])

  @@map("movimentacoes_estoque")
}

// ==========================================
// MÓDULO FINANCEIRO
// ==========================================

model LancamentoFinanceiro {
  id                 String           @id @default(uuid())
  clienteId          String
  leadId             String?
  vendaId            String?
  categoriaId        String?
  descricao          String
  valor              Float
  tipo               TipoLancamento
  status             StatusFinanceiro @default(PENDENTE)
  dataVencimento     DateTime
  dataPagamento      DateTime?
  dataCancelamento   DateTime?
  motivoCancelamento String?
  idAgrupamento      String?
  criadoEm           DateTime         @default(now())
  atualizadoEm       DateTime         @updatedAt

  cliente   Cliente              @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  lead      Lead?                @relation(fields: [leadId], references: [id])
  venda     Venda?               @relation(fields: [vendaId], references: [id])
  categoria CategoriaFinanceira? @relation(fields: [categoriaId], references: [id])

  @@map("lancamentos_financeiros")
}

model CategoriaFinanceira {
  id        String         @id @default(uuid())
  clienteId String
  nome      String
  tipo      TipoLancamento

  cliente     Cliente                @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  lancamentos LancamentoFinanceiro[]
  produtos    Produto[]

  @@map("categorias_financeiras")
}

model Alerta {
  id           String      @id @default(uuid())
  botId        String
  clienteId    String
  usuarioId    String?
  severidade   Severidade  @default(ERROR)
  titulo       String
  mensagem     String
  status       StatusAlerta @default(OPEN)
  resolvidoEm  DateTime?
  criadoEm     DateTime    @default(now())
  atualizadoEm DateTime    @updatedAt
  bot          Bot         @relation(fields: [botId], references: [id], onDelete: Cascade)
  cliente      Cliente     @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  usuario      Usuario?    @relation(fields: [usuarioId], references: [id])

  @@map("alertas")
}

// ==========================================
// ENUMS
// ==========================================

enum Perfil {
  ADMIN
  VIEWER
  CLIENT
}

enum Plano {
  BASIC
  PRO
  PREMIUM
}

enum StatusCliente {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum StatusBot {
  ONLINE
  OFFLINE
  ERROR
}

enum Canal {
  WHATSAPP
  INSTAGRAM
  WEBSITE
  TELEGRAM
}

enum Severidade {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum StatusAlerta {
  OPEN
  RESOLVED
  IGNORED
}

enum TipoGatilho {
  KEYWORD
  DEFAULT
  ALWAYS
}

enum TipoNo {
  MESSAGE
  QUESTION
  CONDITION
  DELAY
  HTTP_REQUEST
  UPDATE_LEAD
}

enum TipoVariavel {
  TEXT
  NUMBER
  BOOLEAN
}

enum ProvedorIA {
  OPENAI
  ANTHROPIC
  DEEPSEEK
  CUSTOM
  GEMINI
}

enum StatusAgendamento {
  PENDING
  CONFIRMED
  CANCELED
  COMPLETED
}

enum StatusVenda {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum Prioridade {
  LOW
  MEDIUM
  HIGH
}

enum OrigemAgendamento {
  MANUAL
  AI
}

enum VisibilidadeProduto {
  ATIVO
  PAUSADO
  ARQUIVADO
}

enum TipoProduto {
  FISICO
  SERVICO
}

enum TipoMovimentacao {
  VENDA
  AJUSTE
  DEVOLUCAO
  COMPRA_FORNECEDOR
  RESERVA
}

enum StatusFinanceiro {
  PENDENTE
  PAGO
  ATRASADO
  CANCELADO
}

enum TipoLancamento {
  RECEITA
  DESPESA
}
