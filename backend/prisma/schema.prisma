generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// USUÁRIOS E CLIENTES
// ==========================================

model Usuario {
  id                 String       @id @default(uuid())
  nome               String
  email              String       @unique
  senha              String
  perfil             Perfil       @default(ADMIN)
  permissoes         Json?        @default("{}")
  deveTrocarSenha    Boolean      @default(false)
  foto               String? // URL ou data-URL base64 da foto pessoal
  criadoEm           DateTime     @default(now())
  atualizadoEm       DateTime     @updatedAt
  clienteId          String?
  alertas            Alerta[]
  cliente            Cliente?     @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  execucoes          Execucao[]
  credenciaisCriadas Credencial[]

  @@map("usuarios")
}

model Cliente {
  id                     String                 @id @default(uuid())
  nome                   String
  email                  String?                @unique
  telefone               String?
  segmento               String?
  plano                  Plano                  @default(BASIC)
  status                 StatusCliente          @default(ACTIVE)
  mensalidade            Float                  @default(0)
  observacoes            String?
  modulosLiberados       Json                   @default("{}")
  brandLogo              String? // URL ou data-URL base64 do logo
  brandNome              String? // Nome customizado que substitui "Sellergy Cloud" no menu
  criadoEm               DateTime               @default(now())
  atualizadoEm           DateTime               @updatedAt
  alertas                Alerta[]
  agendamentos           Agendamento[]
  bots                   Bot[]
  etapasLead             EtapaLead[]
  leads                  Lead[]
  vendas                 Venda[]
  usuarios               Usuario[]
  produtos               Produto[]
  lancamentosFinanceiros LancamentoFinanceiro[]
  categoriasFinanceiras  CategoriaFinanceira[]
  saldosHistorico        SaldoHistorico[]
  credenciais            Credencial[]

  @@map("clientes")
}

model SaldoHistorico {
  id        String   @id @default(uuid())
  clienteId String
  valor     Float
  motivo    String?
  data      DateTime @default(now())

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("saldo_historico")
}

// ==========================================
// BOTS E AUTOMAÇÃO
// ==========================================

model Bot {
  id                 String        @id @default(uuid())
  clienteId          String
  nome               String
  canal              Canal         @default(WHATSAPP)
  status             StatusBot     @default(OFFLINE)
  telefone           String?
  totalMensagens     Int           @default(0)
  mensagensHoje      Int           @default(0)
  ultimaAtividadeEm  DateTime?
  criadoEm           DateTime      @default(now())
  atualizadoEm       DateTime      @updatedAt
  modeloIa           String?
  provedorIa         ProvedorIA?
  promptSistemaIa    String?
  temperaturaIa      Float?        @default(0.7)
  apiKeyIa           String?
  // Lista de nomes de tools que o agente deste bot pode invocar
  // (ex: ["crm.criarLead", "agenda.criarAgendamento"]). Default vazio = nenhuma.
  toolsHabilitadas   Json          @default("[]")
  // Canal externo (WhatsApp Cloud, Telegram, etc.):
  //   credencialCanalId  -> Credencial (token do canal)
  //   identificadorCanal -> ex: phoneNumberId do WhatsApp / chatId do Telegram
  //   verifyTokenCanal   -> verify token usado pela Meta no GET de verificacao
  //   fluxoPadraoId      -> fluxo disparado quando uma mensagem entra
  credencialCanalId  String?
  identificadorCanal String?
  verifyTokenCanal   String?
  fluxoPadraoId      String?
  alertas            Alerta[]
  variaveis          VariavelBot[]
  cliente            Cliente       @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  fluxos             Fluxo[]       @relation("FluxosDoBot")
  fluxoPadrao        Fluxo?        @relation("FluxoPadraoDoBot", fields: [fluxoPadraoId], references: [id], onDelete: SetNull)

  @@map("bots")
}

model VariavelBot {
  id           String       @id @default(uuid())
  botId        String
  chave        String
  valor        String
  descricao    String?
  tipo         TipoVariavel @default(TEXT)
  criadoEm     DateTime     @default(now())
  atualizadoEm DateTime     @updatedAt
  bot          Bot          @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([botId, chave])
  @@map("bot_variaveis")
}

model Fluxo {
  id                  String             @id @default(uuid())
  botId               String
  nome                String
  ativo               Boolean            @default(false)
  tipoGatilho         TipoGatilho        @default(KEYWORD)
  palavraChaveGatilho String?
  nivelLog            NivelLog           @default(METADATA)
  diasRetencaoSucesso Int                @default(30)
  diasRetencaoErro    Int                @default(90)
  criadoEm            DateTime           @default(now())
  atualizadoEm        DateTime           @updatedAt
  conexoes            Conexao[]
  bot                 Bot                @relation("FluxosDoBot", fields: [botId], references: [id], onDelete: Cascade)
  botsComoFluxoPadrao Bot[]              @relation("FluxoPadraoDoBot")
  nos                 No[]
  execucoes           Execucao[]
  webhooks            Webhook[]
  agendamentosFluxo   AgendamentoFluxo[]

  @@index([botId])
  @@map("fluxos")
}

model No {
  id           String   @id
  fluxoId      String
  tipo         TipoNo
  posicaoX     Float
  posicaoY     Float
  dados        Json
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  fluxo        Fluxo    @relation(fields: [fluxoId], references: [id], onDelete: Cascade)

  @@index([fluxoId])
  @@map("nos")
}

model Conexao {
  id          String   @id
  fluxoId     String
  noOrigemId  String
  noDestinoId String
  pontoOrigem String?
  criadoEm    DateTime @default(now())
  fluxo       Fluxo    @relation(fields: [fluxoId], references: [id], onDelete: Cascade)

  @@index([fluxoId])
  @@map("conexoes")
}

// ==========================================
// EXECUCAO DE FLUXOS (Engine)
// ==========================================

model Execucao {
  id            String         @id @default(uuid())
  fluxoId       String
  status        StatusExecucao @default(PENDENTE)
  modo          ModoExecucao   @default(MANUAL)
  iniciadaEm    DateTime       @default(now())
  finalizadaEm  DateTime?
  duracaoMs     Int?
  dadosGatilho  Json?
  erro          String?
  iniciadaPorId String?
  noTriggerId   String?

  fluxo       Fluxo        @relation(fields: [fluxoId], references: [id], onDelete: Cascade)
  iniciadaPor Usuario?     @relation(fields: [iniciadaPorId], references: [id], onDelete: SetNull)
  nos         ExecucaoNo[]

  @@index([fluxoId, iniciadaEm(sort: Desc)])
  @@index([status])
  @@map("execucoes")
}

model Webhook {
  id              String    @id @default(uuid())
  fluxoId         String
  noId            String    @unique
  segredo         String
  ativo           Boolean   @default(true)
  exigirHmac      Boolean   @default(false)
  descricao       String?
  ultimaChamadaEm DateTime?
  totalChamadas   Int       @default(0)
  criadoEm        DateTime  @default(now())
  atualizadoEm    DateTime  @updatedAt

  fluxo Fluxo @relation(fields: [fluxoId], references: [id], onDelete: Cascade)

  @@index([fluxoId])
  @@map("webhooks")
}

model AgendamentoFluxo {
  id               String    @id @default(uuid())
  fluxoId          String
  noId             String    @unique
  expressaoCron    String
  fusoHorario      String    @default("America/Sao_Paulo")
  ativo            Boolean   @default(true)
  ultimoDisparoEm  DateTime?
  proximoDisparoEm DateTime?
  totalDisparos    Int       @default(0)
  criadoEm         DateTime  @default(now())
  atualizadoEm     DateTime  @updatedAt

  fluxo Fluxo @relation(fields: [fluxoId], references: [id], onDelete: Cascade)

  @@index([fluxoId])
  @@map("agendamentos_fluxo")
}

model ExecucaoNo {
  id           String         @id @default(uuid())
  execucaoId   String
  noId         String
  tipo         TipoNo
  status       StatusExecucao @default(PENDENTE)
  iniciadoEm   DateTime       @default(now())
  finalizadoEm DateTime?
  duracaoMs    Int?
  entrada      Json?
  saida        Json?
  erro         String?

  execucao Execucao @relation(fields: [execucaoId], references: [id], onDelete: Cascade)

  @@index([execucaoId])
  @@map("execucoes_nos")
}

// ==========================================
// CRM E LEADS
// ==========================================

model EtapaLead {
  id           String   @id @default(uuid())
  clienteId    String
  nome         String
  ordem        Int
  cor          String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  cliente      Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  leads        Lead[]

  @@map("lead_etapas")
}

model Lead {
  id                     String                 @id @default(uuid())
  clienteId              String
  etapaId                String?
  nome                   String
  telefone               String?
  email                  String?
  valor                  Float?
  observacoes            String?
  ultimoContato          DateTime?
  criadoEm               DateTime               @default(now())
  atualizadoEm           DateTime               @updatedAt
  tags                   String?
  prioridade             Prioridade             @default(MEDIUM)
  origem                 String?
  agendamentos           Agendamento[]
  historico              HistoricoLead[]
  cliente                Cliente                @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  etapa                  EtapaLead?             @relation(fields: [etapaId], references: [id])
  mensagens              Mensagem[]
  vendas                 Venda[]
  lancamentosFinanceiros LancamentoFinanceiro[]
  variacoes              LeadVariacao[]

  @@map("leads")
}

model HistoricoLead {
  id          String   @id @default(uuid())
  leadId      String
  acao        String
  deEtapa     String?
  paraEtapa   String?
  observacoes String?
  criadoEm    DateTime @default(now())
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_historico")
}

model Mensagem {
  id       String   @id @default(uuid())
  leadId   String
  conteudo String
  doBot    Boolean  @default(false)
  criadoEm DateTime @default(now())
  lead     Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("mensagens")
}

model Agendamento {
  id              String            @id @default(uuid())
  clienteId       String
  leadId          String?
  nomeCliente     String
  telefoneCliente String?
  duracao         Int               @default(30)
  origem          OrigemAgendamento @default(MANUAL)
  data            DateTime
  servico         String?
  preco           Float?
  status          StatusAgendamento @default(PENDING)
  observacoes     String?
  criadoEm        DateTime          @default(now())
  atualizadoEm    DateTime          @updatedAt

  cliente   Cliente                @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  lead      Lead?                  @relation(fields: [leadId], references: [id])
  historico HistoricoAgendamento[]

  @@map("agendamentos")
}

// Log auditavel de toda mudanca em agendamento.
// acao: CRIADO | EDITADO | STATUS_MUDADO | EXCLUIDO
// alteracoes: JSON com { campo: { de, para } } pra cada campo modificado
// usuarioId/usuarioNome: quem fez. Null pra acoes do bot (origem AI).
//
// agendamentoId e nullable + ON DELETE SET NULL pra log de EXCLUIDO sobreviver
// a delete do proprio agendamento (auditoria precisa preservar o trail mesmo
// depois). Quando isso acontece, identificamos pelo snapshot guardado nas
// alteracoes.
model HistoricoAgendamento {
  id            String   @id @default(uuid())
  agendamentoId String?
  acao          String
  alteracoes    Json?
  usuarioId     String?
  usuarioNome   String?
  origem        String?
  criadoEm      DateTime @default(now())

  agendamento Agendamento? @relation(fields: [agendamentoId], references: [id], onDelete: SetNull)

  @@index([agendamentoId, criadoEm])
  @@map("agendamento_historico")
}

model Venda {
  id                     String                 @id @default(uuid())
  clienteId              String
  // Numero sequencial humano-legivel por tenant. Cada tenant comeca em 1.
  // O `id` UUID continua sendo a chave tecnica (relacionamentos seguros).
  // O `numero` e o que aparece pra cliente final ("Venda #42").
  numero                 Int
  leadId                 String?
  valor                  Float
  metodoPagamento        String?
  status                 StatusVenda            @default(COMPLETED)
  descricao              String?
  data                   DateTime               @default(now())
  dataCancelamento       DateTime?
  motivoCancelamento     String?
  canceladaPorId         String?
  criadoEm               DateTime               @default(now())
  atualizadoEm           DateTime               @updatedAt
  cliente                Cliente                @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  lead                   Lead?                  @relation(fields: [leadId], references: [id])
  lancamentosFinanceiros LancamentoFinanceiro[]
  movimentacoesEstoque   MovimentacaoEstoque[]

  @@unique([clienteId, numero])
  @@map("vendas")
}

// ==========================================
// MÓDULO DE CATÁLOGO
// ==========================================

model Produto {
  id           String              @id @default(uuid())
  clienteId    String
  categoriaId  String?
  nome         String
  descricao    String?
  tipo         TipoProduto         @default(FISICO)
  visibilidade VisibilidadeProduto @default(ATIVO)
  imagemUrl    String? // URL no MinIO (bucket sellergy-midia)
  criadoEm     DateTime            @default(now())
  atualizadoEm DateTime            @updatedAt

  cliente   Cliente              @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  categoria CategoriaFinanceira? @relation(fields: [categoriaId], references: [id])
  variacoes VariacaoProduto[]

  @@map("produtos")
}

model VariacaoProduto {
  id                String   @id @default(uuid())
  produtoId         String
  nome              String // Ex: "Tamanho P", "Cor Azul"
  sku               String?  @unique
  preco             Float // Preço de Venda (estoque)
  precoCatalogo     Float? // Preço alternativo exibido no catálogo público
  usarPrecoCatalogo Boolean  @default(false) // Quando true, vendas/agenda usam precoCatalogo
  precoCusto        Float?   @default(0) // Preço de Compra
  estoqueAtual      Int      @default(0)
  estoqueMinimo     Int?     @default(0)
  estoqueIdeal      Int?     @default(0)
  localizacao       String?
  // Duracao em minutos — so faz sentido pra produtos do tipo SERVICO (ex.:
  // "Corte de cabelo: 30min"). Usado pela Agenda pra pre-preencher e
  // calcular conflito de horario. Null pra produtos fisicos.
  duracaoMin        Int?
  imagemUrl         String? // imagem opcional da variacao (ex.: cor azul vs cor vermelha)
  criadoEm          DateTime @default(now())
  atualizadoEm      DateTime @updatedAt

  produto       Produto               @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  movimentacoes MovimentacaoEstoque[]
  vinculosLead  LeadVariacao[]

  @@map("variacoes_produto")
}

// ==========================================
// PRODUTOS VINCULADOS AO LEAD (interesse de compra)
// ==========================================
// Tabela M:N entre Lead e VariacaoProduto, com quantidade pra suportar
// "2x camiseta P + 1x camiseta G". O `valor` agregado do lead e calculado
// no servidor a partir dessa relacao (preco × quantidade respeitando
// usarPrecoCatalogo).
model LeadVariacao {
  id          String   @id @default(uuid())
  leadId      String
  variacaoId  String
  quantidade  Int      @default(1)
  observacao  String?
  criadoEm    DateTime @default(now())

  lead     Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  variacao VariacaoProduto @relation(fields: [variacaoId], references: [id], onDelete: Cascade)

  @@unique([leadId, variacaoId])
  @@index([leadId])
  @@map("lead_variacoes")
}

// ==========================================
// MÓDULO DE ESTOQUE
// ==========================================

model MovimentacaoEstoque {
  id         String           @id @default(uuid())
  variacaoId String
  tipo       TipoMovimentacao
  quantidade Int // Positivo para entrada, negativo para saída
  motivo     String?
  vendaId    String?
  data       DateTime         @default(now())

  variacao VariacaoProduto @relation(fields: [variacaoId], references: [id], onDelete: Cascade)
  venda    Venda?          @relation(fields: [vendaId], references: [id])

  @@map("movimentacoes_estoque")
}

// ==========================================
// MÓDULO FINANCEIRO
// ==========================================

model LancamentoFinanceiro {
  id                 String           @id @default(uuid())
  clienteId          String
  leadId             String?
  vendaId            String?
  categoriaId        String?
  descricao          String
  produto            String?
  metodoPagamento    String?
  valor              Float
  tipo               TipoLancamento
  status             StatusFinanceiro @default(PENDENTE)
  dataVencimento     DateTime
  dataPagamento      DateTime?
  dataCancelamento   DateTime?
  motivoCancelamento String?
  idAgrupamento      String?
  criadoEm           DateTime         @default(now())
  atualizadoEm       DateTime         @updatedAt

  cliente   Cliente              @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  lead      Lead?                @relation(fields: [leadId], references: [id])
  venda     Venda?               @relation(fields: [vendaId], references: [id])
  categoria CategoriaFinanceira? @relation(fields: [categoriaId], references: [id])

  @@map("lancamentos_financeiros")
}

model CategoriaFinanceira {
  id        String         @id @default(uuid())
  clienteId String
  nome      String
  tipo      TipoLancamento

  cliente     Cliente                @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  lancamentos LancamentoFinanceiro[]
  produtos    Produto[]

  @@map("categorias_financeiras")
}

model Alerta {
  id           String       @id @default(uuid())
  botId        String
  clienteId    String
  usuarioId    String?
  severidade   Severidade   @default(ERROR)
  titulo       String
  mensagem     String
  status       StatusAlerta @default(OPEN)
  resolvidoEm  DateTime?
  criadoEm     DateTime     @default(now())
  atualizadoEm DateTime     @updatedAt
  bot          Bot          @relation(fields: [botId], references: [id], onDelete: Cascade)
  cliente      Cliente      @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  usuario      Usuario?     @relation(fields: [usuarioId], references: [id])

  @@map("alertas")
}

// ==========================================
// CONVERSAS E MENSAGENS (cifradas em repouso)
// ==========================================

model Conversa {
  id            String             @id @default(uuid())
  clienteId     String
  leadId        String?
  botId         String?
  canal         Canal              @default(WHATSAPP)
  identificador String? // ex: telefone do contato no canal externo
  estado        Json               @default("{}") // estado livre do fluxo manual (ex.: { passo: 'NOME', nome: 'Joao' })
  ultimaMsgEm   DateTime?
  criadoEm      DateTime           @default(now())
  atualizadoEm  DateTime           @updatedAt
  mensagens     MensagemConversa[]

  @@index([clienteId, ultimaMsgEm(sort: Desc)])
  @@index([leadId])
  @@map("conversas")
}

model MensagemConversa {
  id              String                @id @default(uuid())
  conversaId      String
  clienteId       String // duplicado p/ filtro multi-tenant rapido
  sentido         SentidoMensagem
  autor           AutorMensagem
  autorUsuarioId  String?
  tipo            TipoMensagem          @default(TEXTO)
  statusEntrega   StatusEntregaMensagem @default(PENDENTE)
  conteudoCifrado Bytes // ciphertext AES-256-GCM
  iv              Bytes // 12 bytes
  tag             Bytes // 16 bytes
  versaoChave     Int                   @default(1)
  midiaUrl        String? // referencia no MinIO; conteudo em bytes nao no banco
  midiaTipoMime   String?
  metadata        Json? // metadata em CLARO (sem PII)
  criadoEm        DateTime              @default(now())

  conversa Conversa @relation(fields: [conversaId], references: [id], onDelete: Cascade)

  @@index([conversaId, criadoEm])
  @@index([clienteId])
  @@map("mensagens_conversa")
}

model AuditoriaMensagem {
  id         String   @id @default(uuid())
  mensagemId String
  usuarioId  String?
  acao       String // 'LEITURA', 'CRIACAO', 'EXCLUSAO'
  ip         String?
  userAgent  String?
  criadoEm   DateTime @default(now())

  @@index([mensagemId, criadoEm(sort: Desc)])
  @@index([usuarioId])
  @@map("auditoria_mensagens")
}

// Audit append-only de toda chamada de tool feita por agentes IA.
// Permite auditar "o que o bot fez" em cada execucao.
model AuditoriaAcaoAgente {
  id         String   @id @default(uuid())
  execucaoId String
  noId       String?
  toolNome   String
  args       Json?
  sucesso    Boolean
  resultado  Json?
  erro       String?
  duracaoMs  Int?
  criadoEm   DateTime @default(now())

  @@index([execucaoId, criadoEm])
  @@index([toolNome])
  @@map("auditoria_acoes_agente")
}

// Credenciais cifradas (chaves de API de provedores externos: OpenAI,
// Anthropic, WhatsApp Cloud, Telegram, etc.). dadosCifrados guarda um
// objeto JSON serializado e cifrado (AES-256-GCM) — formato livre por tipo.
model Credencial {
  id            String         @id @default(uuid())
  clienteId     String
  nome          String
  tipo          TipoCredencial
  descricao     String?
  dadosCifrados Bytes
  iv            Bytes
  tag           Bytes
  versaoChave   Int            @default(1)
  ultimoUsoEm   DateTime?
  criadoPorId   String?
  criadoEm      DateTime       @default(now())
  atualizadoEm  DateTime       @updatedAt

  cliente   Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  criadoPor Usuario? @relation(fields: [criadoPorId], references: [id], onDelete: SetNull)

  @@index([clienteId, tipo])
  @@map("credenciais")
}

// ==========================================
// ENUMS
// ==========================================

enum Perfil {
  ADMIN
  VIEWER
  CLIENT
  ADMINISTRADOR
  VENDEDOR
}

enum Plano {
  BASIC
  PRO
  PREMIUM
}

enum StatusCliente {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum StatusBot {
  ONLINE
  OFFLINE
  ERROR
}

enum Canal {
  WHATSAPP
  INSTAGRAM
  WEBSITE
  TELEGRAM
}

enum Severidade {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum StatusAlerta {
  OPEN
  RESOLVED
  IGNORED
}

enum TipoGatilho {
  KEYWORD
  DEFAULT
  ALWAYS
}

enum TipoNo {
  MESSAGE
  QUESTION
  CONDITION
  DELAY
  HTTP_REQUEST
  UPDATE_LEAD
  // Nos do MVP do engine de workflows (Fase 1)
  MANUAL
  IF
  SET
  CODE
  // Triggers da Fase 2
  WEBHOOK
  SCHEDULE
  // IA — Fase 3
  AI_AGENT
  // Canais — envio direto pelo canal externo (WhatsApp/Telegram)
  ENVIAR_MENSAGEM
  // Conversa — manipulacao de estado pra fluxos multi-turno deterministicos
  SET_ESTADO_CONVERSA
  // Acao programatica — invoca uma tool do agente direto do builder
  TOOL
  // Switch — bifurca em N saidas baseado no valor de uma expressao (substitui IF aninhado)
  SWITCH
}

enum StatusExecucao {
  PENDENTE
  EM_EXECUCAO
  SUCESSO
  ERRO
  CANCELADA
}

enum ModoExecucao {
  MANUAL
  WEBHOOK
  SCHEDULE
