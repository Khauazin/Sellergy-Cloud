// =====================================================================
// NOTIFICAÇÕES — sino + opt-in por tipo
// =====================================================================
// `Notificacao` é cada item exibido no sino. Pode ser direcionada a um
// usuário específico (usuarioId não nulo) ou ao tenant inteiro (todos os
// usuários do `clienteId` veem).
//
// `lida` é por notificação. Para "marcar todas como lidas", o backend
// atualiza em lote.
//
// `link` é uma rota interna do frontend pra abrir ao clicar (ex.:
// "/app/relatorios/mensal/2026-04"). Opcional.
//
// `dados` é payload JSON livre — útil pra notificações tipadas que o
// frontend precisa renderizar diferente.
//
// Index composto (usuarioId, lida) + (clienteId, criadoEm) atende as
// consultas mais comuns sem table scan.

enum TipoNotificacao {
  LEMBRETE_FECHAMENTO_MES // dia 1 e 5: lance suas despesas
  RELATORIO_MENSAL_PRONTO // dia 7: relatório do mês anterior disponível
  CAIXA_AUTO_FECHADO // cron diário fechou caixa do bot
  CAIXA_DIVERGENCIA // fechamento manual com diferença != 0
  CONTA_PAGAR_VENCENDO // contas a pagar com diaVencimento próximo
  GENERICA // tipo livre pra avisos avulsos
}

model Notificacao {
  id        String          @id @default(uuid())
  clienteId String // tenant
  usuarioId String? // nullable = vai pra todos os usuários do tenant
  tipo      TipoNotificacao
  titulo    String
  mensagem  String
  link      String? // rota interna pra abrir ao clicar (opcional)
  dados     Json? // payload livre pra renderização customizada
  lida      Boolean         @default(false)
  lidaEm    DateTime?
  criadoEm  DateTime        @default(now())

  cliente Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  usuario Usuario? @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, lida])
  @@index([clienteId, criadoEm])
  @@map("notificacoes")
}

// Opt-in/opt-out por tipo. Sem registro = considera ativo (padrão).
// Quando o usuário desativa um tipo, criamos a linha com `ativa=false`.
// Helper `criarNotificacao` consulta antes de gravar.
model PreferenciaNotificacao {
  id           String          @id @default(uuid())
  usuarioId    String
  tipo         TipoNotificacao
  ativa        Boolean         @default(true)
  atualizadoEm DateTime        @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, tipo])
  @@map("preferencias_notificacao")
}

// =====================================================================
// RELATÓRIO MENSAL — snapshot persistido do fechamento de cada mês
// =====================================================================
// Gerado automaticamente pelo cron no dia 7 de cada mês, com os dados do
// mês ANTERIOR. Snapshot é imutável depois de criado: se o usuário editar
// algum lançamento retroativamente, o relatório do mês passado NÃO muda.
// Garante estabilidade contábil — "o que foi fechado, foi fechado".
//
// Regras:
//   - Apenas sessões de caixa FECHADAS entre 1º e último dia do mês contam.
//     Sessão que abriu dia 30 e fechou dia 5 vai pro mês seguinte (porque
//     foi nesse mês que ela foi fechada).
//   - Lançamentos consideram dataPagamento (PAGO) dentro do mês.
//   - Unique (clienteId, ano, mes) — só um snapshot por mês por tenant.

model RelatorioMensal {
  id        String   @id @default(uuid())
  clienteId String
  ano       Int
  mes       Int // 1-12
  dados     Json // snapshot completo (KPIs + listas)
  geradoEm  DateTime @default(now())
  // Opcional: identifica como foi gerado (cron automático vs. botão manual).
  geradoPor String? // 'CRON' | 'MANUAL' | usuarioId

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@unique([clienteId, ano, mes])
  @@index([clienteId, ano, mes])
  @@map("relatorios_mensais")
}
