# ==========================================================================
# Sellergy Cloud — variáveis de PRODUÇÃO (modelo). Copie para `.env` e preencha.
# NÃO comite o .env real. Gere segredos fortes (openssl rand -hex 32).
# ==========================================================================

# --- Banco (Postgres) ---
DB_USER=sellergy
DB_PASSWORD=Sellergy_db
DB_NAME=sellergy
# DB_PORT não é usado em produção (o Postgres não expõe porta pública).
NGROK_DOMAIN=jorge-combinatorial-harland.ngrok-free.dev
NGROK_AUTHTOKEN=2zsCOAEoKJau07xE8zTuY6bhUAe_3PV491gjxD21S7ut2B7h6

# --- Backend ---
BACKEND_PORT=3333
NODE_ENV=production
# Segredos: gere com `openssl rand -hex 32`. NUNCA reutilize os de dev.
JWT_SECRET=troque-32-bytes-aleatorios
MENSAGENS_MASTER_KEY=troque-32-bytes-aleatorios
# Domínios do front autorizados a chamar a API (separados por vírgula). SEM localhost em prod.
CORS_ORIGINS=https://app.seu-dominio.com
# Emissão fiscal real só quando VOCÊ decidir (deixe false até a homologação SEFAZ).
FISCAL_LIVE=false
# WhatsApp: envio real só quando integrar de verdade.
WHATSAPP_ENVIO_REAL=false
WHATSAPP_GRAPH_VERSAO=v21.0

# --- Front (embutido no BUILD do Vite) ---
# URL pública do backend que o navegador vai chamar.
VITE_API_URL=https://jorge-combinatorial-harland.ngrok-free.dev
VITE_URL_PUBLICA=https://jorge-combinatorial-harland.ngrok-free.dev
# Porta pública do nginx do front (80 por padrão; use um proxy TLS na frente).
FRONTEND_PORT=80

# --- MinIO (armazenamento de mídia) ---
MINIO_ROOT_USER=sellergy
MINIO_ROOT_PASSWORD=sellergy_mq
MINIO_ACCESS_KEY=sellergy
MINIO_SECRET_KEY=sellergy_mq
# ENDPOINT precisa ser PÚBLICO pra as URLs assinadas abrirem no navegador
# (ex.: um subdomínio cdn.seu-dominio.com apontando pro MinIO via proxy).
MINIO_ENDPOINT=https://cdn.seu-dominio.com
MINIO_USE_SSL=true
MINIO_REGION=us-east-1
MINIO_BUCKET_MIDIA=sellergy-midia

# --- Somente DEV (não precisa em produção) ---
# PGADMIN_EMAIL / PGADMIN_PASSWORD / NGROK_AUTHTOKEN / NGROK_DOMAIN
# MINIO_API_PORT / MINIO_CONSOLE_PORT
